-- Hàm tạo nút
local function createButton(text, position, color, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = UDim2.new(0.05, 0, position, 0)
    btn.BackgroundColor3 = color or Color3.fromRGB(40, 40, 60)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 13
    btn.Parent = mainFrame
    btn.MouseButton1Click:Connect(callback)
    return btn
end

local function createToggle(text, position, callback)
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0.9, 0, 0, 35)
    toggle.Position = UDim2.new(0.05, 0, position, 0)
    toggle.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
    toggle.Text = text .. " 🔴 OFF"
    toggle.TextColor3 = Color3.fromRGB(255, 100, 100)
    toggle.TextSize = 13
    toggle.Parent = mainFrame
    
    local state = false
    toggle.MouseButton1Click:Connect(function()
        state = not state
        if state then
            toggle.Text = text .. " 🟢 ON"
            toggle.TextColor3 = Color3.fromRGB(100, 255, 100)
        else
            toggle.Text = text .. " 🔴 OFF"
            toggle.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
        callback(state)
    end)
    return toggle, function() return state end
end

