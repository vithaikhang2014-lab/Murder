-- ========== ESP ==========
local espObjects = {}
local roleColors = {
    Murderer = Color3.fromRGB(255, 0, 0),      -- Đỏ
    Sheriff = Color3.fromRGB(0, 150, 255),     -- Xanh nước biển
    Innocent = Color3.fromRGB(0, 255, 0),      -- Xanh lá
    Hero = Color3.fromRGB(255, 215, 0)         -- Vàng
}

local function getPlayerRole(player)
    -- Kiểm tra các dấu hiệu nhận biết role trong game
    local character = player.Character
    if not character then return "Innocent" end
    
    -- Nếu có knife tool -> sát nhân
    if player.Backpack:FindFirstChild("Knife") or character:FindFirstChild("Knife") then
        return "Murderer"
    end
    
    -- Nếu có gun -> cảnh sát hoặc anh hùng
    local hasGun = player.Backpack:FindFirstChild("Gun") or character:FindFirstChild("Gun")
    if hasGun then
        -- Kiểm tra xem có phải hero không (hero thường có skin đặc biệt)
        if character:FindFirstChild("Head") and character.Head:FindFirstChild("Handle") then
            return "Hero"
        end
        return "Sheriff"
    end
    
    return "Innocent"
end

local function getDroppedGun()
    for _, item in pairs(workspace:GetDescendants()) do
        if item:IsA("Tool") and (item.Name:lower():find("gun") or item.Name:lower():find("revolver")) then
            return item
        end
    end
    return nil
end

local function updateESP()
    for _, v in pairs(espObjects) do pcall(function() v:Destroy() end) end
    espObjects = {}
    
    if not getEspState() then return end
    
    -- ESP cho người chơi
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") then
            local role = getPlayerRole(plr)
            local color = roleColors[role] or roleColors.Innocent
            
            local head = plr.Character.Head
            
            local billboard = Instance.new("BillboardGui")
            billboard.Size = UDim2.new(0, 4, 0, 4)
            billboard.StudsOffset = Vector3.new(0, 1.5, 0)
            billboard.AlwaysOnTop = true
            billboard.Parent = head
            
            local box = Instance.new("Frame")
            box.Size = UDim2.new(0, 6, 0, 6)
            box.BackgroundColor3 = color
            box.BorderSizePixel = 0
            box.Parent = billboard
            
            local nameTag = Instance.new("BillboardGui")
            nameTag.Size = UDim2.new(0, 120, 0, 25)
            nameTag.StudsOffset = Vector3.new(0, 2.2, 0)
            nameTag.AlwaysOnTop = true
            nameTag.Parent = head
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, 0, 1, 0)
            nameLabel.BackgroundTransparency = 0.5
            nameLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            nameLabel.Text = plr.Name .. " [" .. role .. "]"
            nameLabel.TextColor3 = color
            nameLabel.TextSize = 11
            nameLabel.Font = Enum.Font.GothamBold
            nameLabel.Parent = nameTag
            
            table.insert(espObjects, billboard)
            table.insert(espObjects, nameTag)
        end
    end
    
    -- ESP cho súng rơi [citation:1][citation:2]
    local gun = getDroppedGun()
    if gun and gun.Parent == workspace then
        local gunBillboard = Instance.new("BillboardGui")
        gunBillboard.Size = UDim2.new(0, 4, 0, 4)
        gunBillboard.StudsOffset = Vector3.new(0, 0.5, 0)
        gunBillboard.AlwaysOnTop = true
        gunBillboard.Parent = gun
        
        local gunFrame = Instance.new("Frame")
        gunFrame.Size = UDim2.new(0, 8, 0, 8)
        gunFrame.BackgroundColor3 = Color3.fromRGB(255, 165, 0) -- Màu cam
        gunFrame.BorderSizePixel = 0
        gunFrame.Parent = gunBillboard
        
        local gunTag = Instance.new("BillboardGui")
        gunTag.Size = UDim2.new(0, 80, 0, 20)
        gunTag.StudsOffset = Vector3.new(0, 1, 0)
        gunTag.AlwaysOnTop = true
        gunTag.Parent = gun
        
        local gunLabel = Instance.new("TextLabel")
        gunLabel.Size = UDim2.new(1, 0, 1, 0)
        gunLabel.BackgroundTransparency = 0.5
        gunLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        gunLabel.Text = "🔫 GUN"
        gunLabel.TextColor3 = Color3.fromRGB(255, 165, 0)
        gunLabel.TextSize = 10
        gunLabel.Font = Enum.Font.GothamBold
        gunLabel.Parent = gunTag
        
        table.insert(espObjects, gunBillboard)
        table.insert(espObjects, gunTag)
    end
end

-- ========== SILENT AIM (Bám đầu khi ấn chuột phải) ==========
local rightMousePressed = false

local function getClosestPlayerToCursor()
    local mouseLoc = UserInputService:GetMouseLocation()
    local center = Vector2.new(mouseLoc.X, mouseLoc.Y)
    local bestDist = 100
    local bestHead = nil
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            local head = plr.Character:FindFirstChild("Head")
            if head then
                local screenPos, onScreen = Camera:WorldToScreenPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestHead = head
                    end
                end
            end
        end
    end
    return bestHead
end

