-- ========== ESP ==========
local espObjects = {}
local roleColors = {
    Murderer = Color3.fromRGB(255, 0, 0),
    Sheriff = Color3.fromRGB(0, 150, 255),
    Innocent = Color3.fromRGB(0, 255, 0),
    Hero = Color3.fromRGB(255, 215, 0)
}

local function getPlayerRole(player)
    if player:FindFirstChild("Backpack") then
        if player.Backpack:FindFirstChild("Knife") then return "Murderer" end
        if player.Backpack:FindFirstChild("Gun") then return "Sheriff" end
    end
    if player.Character then
        if player.Character:FindFirstChild("Knife") then return "Murderer" end
        if player.Character:FindFirstChild("Gun") then return "Sheriff" end
        if player.Character:FindFirstChild("Head") and player.Character.Head:FindFirstChild("Handle") then
            return "Hero"
        end
    end
    return "Innocent"
end

local function updateESP()
    for _, v in pairs(espObjects) do pcall(function() v:Destroy() end) end
    espObjects = {}
    if not getEspState() then return end
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") then
            local role = getPlayerRole(plr)
            local color = roleColors[role] or roleColors.Innocent
            local head = plr.Character.Head
            
            local bill = Instance.new("BillboardGui")
            bill.Size = UDim2.new(0, 4, 0, 4)
            bill.StudsOffset = Vector3.new(0, 1.5, 0)
            bill.AlwaysOnTop = true
            bill.Parent = head
            
            local box = Instance.new("Frame")
            box.Size = UDim2.new(0, 6, 0, 6)
            box.BackgroundColor3 = color
            box.BorderSizePixel = 0
            box.Parent = bill
            
            local nameTag = Instance.new("BillboardGui")
            nameTag.Size = UDim2.new(0, 130, 0, 25)
            nameTag.StudsOffset = Vector3.new(0, 2.2, 0)
            nameTag.AlwaysOnTop = true
            nameTag.Parent = head
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, 0, 1, 0)
            nameLabel.BackgroundTransparency = 0.5
            nameLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            nameLabel.Text = plr.Name .. " [" .. role .. "]"
            nameLabel.TextColor3 = color
            nameLabel.TextSize = 10
            nameLabel.Font = Enum.Font.GothamBold
            nameLabel.Parent = nameTag
            
            table.insert(espObjects, bill)
            table.insert(espObjects, nameTag)
        end
    end
end

-- ========== SHOT MURDER (BẮN CHẾT MURDERER NGAY TỨC KHẮC) ==========
local function getMurderer()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and getPlayerRole(plr) == "Murderer" then
            return plr
        end
    end
    return nil
end

shotButton.MouseButton1Click:Connect(function()
    local murderer = getMurderer()
    if murderer and murderer.Character then
        local head = murderer.Character:FindFirstChild("Head")
        if head then
            -- Tạo effect giống bắn súng
            local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
            if tool and tool:FindFirstChild("Fire") then
                tool.Fire:FireServer(head.CFrame, head)
            else
                -- Nếu không có súng, dùng remote khác (game thường dùng RemoteEvent)
                local remote = ReplicatedStorage:FindFirstChild("GunEvent") or ReplicatedStorage:FindFirstChild("Shoot")
                if remote then
                    remote:FireServer(head.CFrame, head)
                end
            end
            -- Fallback: gây sát thương bằng cách khác
            if head:FindFirstChild("Humanoid") then
                head.Humanoid.Health = 0
            elseif murderer.Character:FindFirstChild("Humanoid") then
                murderer.Character.Humanoid.Health = 0
            end
        end
    end
end)

-- ========== TÙY CHỈNH VAI TRÒ (ÉP LÀM MURDERER Ở LOBBY) ==========
local function forceMurdererInLobby()
    -- Tìm GUI chọn role trong lobby
    task.wait(2)
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if playerGui then
        for _, gui in pairs(playerGui:GetChildren()) do
            if gui:IsA("ScreenGui") then
                for _, btn in pairs(gui:GetDescendants()) do
                    if btn:IsA("TextButton") and btn.Text:lower():find("murderer") then
                        btn:FireClick()
                        return
                    end
                end
            end
        end
    end
    -- Cách 2: Gửi remote nếu có
    local remote = ReplicatedStorage:FindFirstChild("ChooseRole") or ReplicatedStorage:FindFirstChild("SelectRole")
    if remote then
        remote:FireServer("Murderer")
    end
end

